{
  "uid": "esb-router-worker",
  "title": "Router Worker",
  "tags": ["esb", "router-worker"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(routing_decisions_total, exported_job)",
        "label": "Service",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "current": { "text": "", "value": "" }
      },
      {
        "name": "consumer_group",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(kafka_consumergroup_lag, consumergroup)",
        "label": "Consumer Group",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2
      },
      {
        "name": "topic",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(kafka_consumergroup_lag{consumergroup=~\"$consumer_group\"}, topic)",
        "label": "Topic",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Kafka Consumer", "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 2, "title": "Consumer Lag",
      "description": "Источник: kafka-exporter. Сумма отставания по всем партициям выбранного consumer group.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{
        "expr": "sum(kafka_consumergroup_lag{consumergroup=~\"$consumer_group\",topic=~\"$topic\"})",
        "legendFormat": "Lag", "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] } } }
    },
    {
      "id": 3, "title": "Consume Rate",
      "description": "Источник: kafka-exporter. Скорость роста current_offset = скорость потребления.",
      "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{
        "expr": "sum(rate(kafka_consumergroup_current_offset{consumergroup=~\"$consumer_group\",topic=~\"$topic\"}[$__rate_interval]))",
        "legendFormat": "msg/s", "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "mps", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 4, "title": "In-Flight", "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "app_messages_in_flight{exported_job=\"$service\"}", "legendFormat": "In-Flight", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] } } }
    },
    {
      "id": 5, "title": "Broker Fetch P99",
      "description": "Источник: JMX Exporter. Время обработки FetchConsumer запроса на брокере.",
      "type": "stat",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "kafka_broker_fetch_request_duration_ms{quantile=\"999\"} / 1000", "legendFormat": "P99", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] } } }
    },
    {
      "id": 6, "title": "Consumer Lag по топикам и партициям",
      "description": "kafka_consumer_group_lag из kafka-exporter — точный lag с разбивкой по partition.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{
        "expr": "kafka_consumergroup_lag{consumergroup=~\"$consumer_group\",topic=~\"$topic\"}",
        "legendFormat": "{{ topic }} [p{{ partition }}] {{ consumergroup }}", "refId": "A"
      }],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom", "displayMode": "table", "calcs": ["lastNotNull", "max"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 7, "title": "Consume Rate по топикам",
      "description": "rate(kafka_consumer_group_current_offset) — сколько сообщений/сек обрабатывает consumer group.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{
        "expr": "sum(rate(kafka_consumergroup_current_offset{consumergroup=~\"$consumer_group\",topic=~\"$topic\"}[$__rate_interval])) by (topic, consumergroup)",
        "legendFormat": "{{ topic }} / {{ consumergroup }}", "refId": "A"
      }],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "mps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 8 } } }
    },
    {
      "id": 8, "title": "Routing", "type": "row",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 9, "title": "Routing Success Rate", "type": "stat",
      "gridPos": { "x": 0, "y": 14, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(rate(routing_decisions_total{exported_job=\"$service\",routing_result=\"success\"}[$__rate_interval])) / sum(rate(routing_decisions_total{exported_job=\"$service\"}[$__rate_interval])) * 100", "legendFormat": "Success %", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 }] } } }
    },
    {
      "id": 10, "title": "DLQ Rate", "type": "stat",
      "gridPos": { "x": 6, "y": 14, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(rate(routing_dlq_messages_total{exported_job=\"$service\"}[$__rate_interval]))", "legendFormat": "DLQ/s", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "mps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.001 }] } } }
    },
    {
      "id": 11, "title": "Routing P95", "type": "stat",
      "gridPos": { "x": 12, "y": 14, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(routing_decision_duration_seconds_bucket{exported_job=\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "P95", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.025 }, { "color": "red", "value": 0.1 }] } } }
    },
    {
      "id": 12, "title": "Retry Rate", "type": "stat",
      "gridPos": { "x": 18, "y": 14, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(rate(routing_retries_total{exported_job=\"$service\"}[$__rate_interval]))", "legendFormat": "Retries/s", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "mps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 13, "title": "Routing Decisions by Result", "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(rate(routing_decisions_total{exported_job=\"$service\"}[$__rate_interval])) by (routing_result, messaging_topic)", "legendFormat": "{{ routing_result }} — {{ messaging_topic }}", "refId": "A" }],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom", "displayMode": "table", "calcs": ["lastNotNull", "mean"] } },
      "fieldConfig": { "defaults": { "unit": "mps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 8 } } }
    },
    {
      "id": 14, "title": "Routing Duration Percentiles", "type": "timeseries",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(routing_decision_duration_seconds_bucket{exported_job=\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(routing_decision_duration_seconds_bucket{exported_job=\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(routing_decision_duration_seconds_bucket{exported_job=\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom", "displayMode": "table", "calcs": ["lastNotNull", "mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 15, "title": "DLQ по причинам", "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "sum(rate(routing_dlq_messages_total{exported_job=\"$service\"}[$__rate_interval])) by (routing_dlq_reason)", "legendFormat": "{{ routing_dlq_reason }}", "refId": "A" },
        { "expr": "sum(rate(routing_retries_total{exported_job=\"$service\"}[$__rate_interval]))", "legendFormat": "retries", "refId": "B" }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "right", "displayMode": "table", "calcs": ["lastNotNull", "sum"] } },
      "fieldConfig": { "defaults": { "unit": "mps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 15 } } }
    },
    {
      "id": 16, "title": "Kafka Broker (JMX)", "type": "row",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 17, "title": "Broker Messages In Rate",
      "description": "Источник: JMX Exporter. Сколько сообщений в секунду получает брокер по топикам.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "sum(rate(kafka_broker_messages_in_total[$__rate_interval])) by (topic)", "legendFormat": "{{ topic }}", "refId": "A" }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "mps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 8 } } }
    },
    {
      "id": 18, "title": "Broker Produce Request Duration",
      "description": "Источник: JMX Exporter. Время обработки Produce запроса на брокере.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "kafka_broker_produce_request_duration_ms{quantile=\"50\"} / 1000", "legendFormat": "P50", "refId": "A" },
        { "expr": "kafka_broker_produce_request_duration_ms{quantile=\"95\"} / 1000", "legendFormat": "P95", "refId": "B" },
        { "expr": "kafka_broker_produce_request_duration_ms{quantile=\"999\"} / 1000", "legendFormat": "P99.9", "refId": "C" }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom", "displayMode": "table", "calcs": ["lastNotNull", "mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    }
  ]
}