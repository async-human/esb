{
  "uid": "esb-overview",
  "title": "ESB",
  "tags": ["esb"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "query": "prometheus",
        "hide": 0
      },
      {
        "name": "interval",
        "type": "interval",
        "query": "1m,5m,10m,30m",
        "current": { "value": "5m" },
        "hide": 0
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(exported_job)",
        "label": "Service",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "inbound_service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(http_server_request_count_total, exported_job)",
        "label": "Inbound Service",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 2
      },
      {
        "name": "router_service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(kafka_consumer_lag, exported_job)",
        "label": "Router Service",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 2
      },
      {
        "name": "outbound_service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(delivery_attempts_total, exported_job)",
        "label": "Outbound Service",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Health",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Inbound RPS",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total{exported_job=~\"$inbound_service\"}[$__rate_interval]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Router — Consumer Lag",
      "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "sum(kafka_consumer_lag{exported_job=~\"$router_service\"})",
          "legendFormat": "Lag",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Outbound — Consumer Lag",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "sum(kafka_consumer_lag{exported_job=~\"$outbound_service\"})",
          "legendFormat": "Lag",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Delivery Success Rate",
      "type": "stat",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "sum(rate(delivery_attempts_total{exported_job=~\"$outbound_service\",delivery_result=\"success\"}[$__rate_interval])) / sum(rate(delivery_attempts_total{exported_job=~\"$outbound_service\"}[$__rate_interval])) * 100",
          "legendFormat": "Success %",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 }] }
        }
      }
    },
    {
      "id": 6,
      "title": "Message Pipeline",
      "type": "row",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Message Flow (msg/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "sum(rate(kafka_producer_messages_total{exported_job=~\"$inbound_service\"}[$__rate_interval]))",
          "legendFormat": "inbound → kafka",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kafka_consumer_messages_total{exported_job=~\"$router_service\"}[$__rate_interval]))",
          "legendFormat": "router ← kafka",
          "refId": "B"
        },
        {
          "expr": "sum(rate(kafka_producer_messages_total{exported_job=~\"$router_service\"}[$__rate_interval]))",
          "legendFormat": "router → kafka",
          "refId": "C"
        },
        {
          "expr": "sum(rate(kafka_consumer_messages_total{exported_job=~\"$outbound_service\"}[$__rate_interval]))",
          "legendFormat": "outbound ← kafka",
          "refId": "D"
        },
        {
          "expr": "sum(rate(delivery_attempts_total{exported_job=~\"$outbound_service\",delivery_result=\"success\"}[$__rate_interval]))",
          "legendFormat": "outbound → recipient ✓",
          "refId": "E"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "showLegend": true, "placement": "bottom", "displayMode": "table", "calcs": ["lastNotNull", "mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      }
    },
    {
      "id": 8,
      "title": "Errors & DLQ",
      "type": "row",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Error Rates by Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total{exported_job=~\"$inbound_service\",http_response_status_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "inbound HTTP 5xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kafka_producer_errors_total{exported_job=~\"$inbound_service\"}[$__rate_interval]))",
          "legendFormat": "inbound kafka errors",
          "refId": "B"
        },
        {
          "expr": "sum(rate(routing_decisions_total{exported_job=~\"$router_service\",routing_result!=\"success\"}[$__rate_interval]))",
          "legendFormat": "routing errors",
          "refId": "C"
        },
        {
          "expr": "sum(rate(delivery_errors_total{exported_job=~\"$outbound_service\"}[$__rate_interval]))",
          "legendFormat": "delivery errors",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "showLegend": true, "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 10,
      "title": "DLQ Rate (router-worker)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "sum(rate(routing_dlq_messages_total{exported_job=~\"$router_service\"}[$__rate_interval])) by (routing_dlq_reason)",
          "legendFormat": "DLQ — {{ routing_dlq_reason }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(routing_retries_total{exported_job=~\"$router_service\"}[$__rate_interval]))",
          "legendFormat": "retries",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "showLegend": true, "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 11,
      "title": "Latency (P95)",
      "type": "row",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 12,
      "title": "HTTP P95 (inbound-connector)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{exported_job=~\"$inbound_service\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{exported_job=~\"$inbound_service\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{exported_job=~\"$inbound_service\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99", "refId": "C"
        }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 13,
      "title": "Routing P95 (router-worker)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(routing_decision_duration_seconds_bucket{exported_job=~\"$router_service\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(routing_decision_duration_seconds_bucket{exported_job=~\"$router_service\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(routing_decision_duration_seconds_bucket{exported_job=~\"$router_service\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99", "refId": "C"
        }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 14,
      "title": "Delivery P95 (outbound-connector)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(delivery_duration_seconds_bucket{exported_job=~\"$outbound_service\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(delivery_duration_seconds_bucket{exported_job=~\"$outbound_service\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(delivery_duration_seconds_bucket{exported_job=~\"$outbound_service\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99", "refId": "C"
        }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 15,
      "title": "InFlight Messages",
      "type": "row",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 16,
      "title": "In-Flight по сервисам",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        {
          "expr": "app_messages_in_flight{exported_job=~\"$service\"}",
          "legendFormat": "{{exported_job}}", "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 20 } } }
    }
  ]
}
