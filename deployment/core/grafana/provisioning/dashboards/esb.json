{
  "uid": "esb-overview",
  "title": "ESB",
  "tags": ["esb"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "inbound_service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(http_server_request_count_total, exported_job)",
        "label": "Inbound Service",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 2
      },
      {
        "name": "router_service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(routing_decisions_total, exported_job)",
        "label": "Router Service",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 2
      },
      {
        "name": "outbound_service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
        "query": "label_values(delivery_attempts_total, exported_job)",
        "label": "Outbound Service",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Pipeline Health", "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 2, "title": "Inbound RPS", "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(rate(http_server_request_count_total{exported_job=~\"$inbound_service\"}[$__rate_interval]))", "legendFormat": "RPS", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] } } }
    },
    {
      "id": 23, "title": "Inbound → Kafka",
      "description": "Сообщения, принятые inbound-connector и отправленные в Kafka",
      "type": "stat",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(rate(kafka_producer_messages_total{exported_job=~\"$inbound_service\"}[$__rate_interval]))", "legendFormat": "msg/s", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "mps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 3, "title": "Router — Consumer Lag",
      "description": "Источник: kafka-exporter",
      "type": "stat",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(kafka_consumergroup_lag)", "legendFormat": "Total Lag", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] } } }
    },
    {
      "id": 4, "title": "Under-Replicated Partitions",
      "description": "Источник: JMX Exporter. Должно быть 0.",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "kafka_broker_under_replicated_partitions", "legendFormat": "URP", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 24, "title": "Outbound → Delivered",
      "description": "Успешно доставленные сообщения в конечную точку",
      "type": "stat",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(rate(delivery_attempts_total{exported_job=~\"$outbound_service\",delivery_result=\"success\"}[$__rate_interval]))", "legendFormat": "msg/s", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "mps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 5, "title": "Delivery Success Rate", "type": "stat",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(rate(delivery_attempts_total{exported_job=~\"$outbound_service\",delivery_result=\"success\"}[$__rate_interval])) / sum(rate(delivery_attempts_total{exported_job=~\"$outbound_service\"}[$__rate_interval])) * 100", "legendFormat": "Success %", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 }] } } }
    },
    {
      "id": 6, "title": "Message Pipeline", "type": "row",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 7, "title": "Message Flow (msg/s)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "sum(rate(kafka_producer_messages_total{exported_job=~\"$inbound_service\"}[$__rate_interval]))", "legendFormat": "inbound → kafka", "refId": "A" },
        {
          "expr": "sum(rate(kafka_broker_messages_in_total[$__rate_interval])) by (topic)",
          "legendFormat": "broker in: {{ topic }}", "refId": "B"
        },
        { "expr": "sum(rate(kafka_consumergroup_current_offset[$__rate_interval])) by (consumergroup)", "legendFormat": "consumer: {{ consumergroup }}", "refId": "C" },
        { "expr": "sum(rate(delivery_attempts_total{exported_job=~\"$outbound_service\",delivery_result=\"success\"}[$__rate_interval]))", "legendFormat": "outbound → recipient ✓", "refId": "D" }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom", "displayMode": "table", "calcs": ["lastNotNull", "mean"] } },
      "fieldConfig": { "defaults": { "unit": "mps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 8 } } }
    },
    {
      "id": 8, "title": "Kafka Health (JMX)", "type": "row",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 20, "title": "Broker Messages In Rate",
      "description": "Источник: JMX Exporter. Пропускная способность брокера по топикам.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(rate(kafka_broker_messages_in_total[$__rate_interval])) by (topic)", "legendFormat": "{{ topic }}", "refId": "A" }],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "mps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 8 } } }
    },
    {
      "id": 21, "title": "Consumer Lag по группам",
      "description": "Источник: kafka-exporter. Сумма lag по всем партициям каждой consumer group.",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 15, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [{ "expr": "sum(kafka_consumergroup_lag) by (consumergroup)", "legendFormat": "{{ consumergroup }}", "refId": "A" }],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 22, "title": "Broker Request Handler Idle %",
      "description": "Источник: JMX. Если < 20% — брокер перегружен.",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "kafka_broker_request_handler_idle_percent * 100", "legendFormat": "Request Handler Idle %", "refId": "A" },
        { "expr": "kafka_broker_network_processor_idle_percent * 100", "legendFormat": "Network Processor Idle %", "refId": "B" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 20 }, { "color": "green", "value": 50 }] } } }
    },
    {
      "id": 9, "title": "Errors & DLQ", "type": "row",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 10, "title": "Error Rates by Service", "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "sum(rate(http_server_request_count_total{exported_job=~\"$inbound_service\",http_response_status_code=~\"5..\"}[$__rate_interval]))", "legendFormat": "inbound HTTP 5xx", "refId": "A" },
        { "expr": "sum(rate(kafka_producer_errors_total{exported_job=~\"$inbound_service\"}[$__rate_interval]))", "legendFormat": "inbound kafka errors", "refId": "B" },
        { "expr": "sum(rate(routing_decisions_total{exported_job=~\"$router_service\",routing_result!=\"success\"}[$__rate_interval]))", "legendFormat": "routing errors", "refId": "C" },
        { "expr": "sum(rate(delivery_errors_total{exported_job=~\"$outbound_service\"}[$__rate_interval]))", "legendFormat": "delivery errors", "refId": "D" },
        { "expr": "sum(rate(kafka_broker_produce_errors_total[$__rate_interval])) by (error)", "legendFormat": "broker error: {{ error }}", "refId": "E" }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "mps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 11, "title": "DLQ Rate", "type": "timeseries",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "sum(rate(routing_dlq_messages_total{exported_job=~\"$router_service\"}[$__rate_interval])) by (routing_dlq_reason)", "legendFormat": "DLQ — {{ routing_dlq_reason }}", "refId": "A" },
        { "expr": "sum(rate(routing_retries_total{exported_job=~\"$router_service\"}[$__rate_interval]))", "legendFormat": "retries", "refId": "B" }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "mps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 15 } } }
    },
    {
      "id": 12, "title": "Latency (P95)", "type": "row",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 13, "title": "HTTP P95 (inbound)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{exported_job=~\"$inbound_service\"}[$__rate_interval])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{exported_job=~\"$inbound_service\"}[$__rate_interval])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{exported_job=~\"$inbound_service\"}[$__rate_interval])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 14, "title": "Routing P95", "type": "timeseries",
      "gridPos": { "x": 8, "y": 32, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(routing_decision_duration_seconds_bucket{exported_job=~\"$router_service\"}[$__rate_interval])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(routing_decision_duration_seconds_bucket{exported_job=~\"$router_service\"}[$__rate_interval])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(routing_decision_duration_seconds_bucket{exported_job=~\"$router_service\"}[$__rate_interval])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 15, "title": "Delivery P95", "type": "timeseries",
      "gridPos": { "x": 16, "y": 32, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-esb" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(delivery_duration_seconds_bucket{exported_job=~\"$outbound_service\"}[$__rate_interval])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(delivery_duration_seconds_bucket{exported_job=~\"$outbound_service\"}[$__rate_interval])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(delivery_duration_seconds_bucket{exported_job=~\"$outbound_service\"}[$__rate_interval])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    }
  ]
}