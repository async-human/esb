# --- COMMON ---
# Имя проекта для docker networks и контейнеров
COMPOSE_PROJECT_NAME=esb-core
GLOBAL_NETWORK_SUBNET=172.25.0.0/16

# --- POSTGRES ---
POSTGRES_PORT=5432
POSTGRES_USER=esb_admin
POSTGRES_PASSWORD=super_secret_password
POSTGRES_DB=esb_dictionary

# --- KAFKA (Используем KRaft, без Zookeeper) ---
KAFKA_BROKER_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_UI_PORT=8080
KAFKA_CLUSTER_ID=esb-kafka-cluster-id-1

# --- ELASTICSEARCH ---
ELASTIC_PORT=9200
ELASTIC_PASSWORD=elastic_pass
ELASTIC_MEMORY=512m

# --- JAEGER ---
JAEGER_UI_PORT=16686
JAEGER_OTLP_PORT=4317

# --- PROMETHEUS ---
PROMETHEUS_PORT=9090

# --- GRAFANA ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin